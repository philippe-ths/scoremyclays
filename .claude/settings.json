{
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git remote:*)",
      "Bash(git rev-parse:*)",
      "Bash(git merge-base:*)",
      "Bash(git ls-tree:*)",
      "Bash(git config:*)",
      "Bash(git stash list:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git rebase:*)",
      "Bash(git restore:*)",
      "Bash(git stash push:*)",
      "Bash(git stash pop:*)",
      "Bash(git stash apply:*)",
      "Bash(git stash drop:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(gh issue:*)",
      "Bash(gh pr:*)",
      "Bash(gh repo:*)",
      "Bash(gh auth:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(awk:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(echo:*)",
      "Bash(pwd)",
      "Bash(tree:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(diff:*)",
      "Bash(file:*)",
      "Bash(dirname:*)",
      "Bash(basename:*)",
      "Bash(realpath:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(touch:*)",
      "Bash(npm test:*)",
      "Bash(npm run:*)",
      "Bash(npm list:*)",
      "Bash(npm outdated:*)",
      "Bash(npm ls:*)",
      "Bash(npx:*)",
      "Bash(yarn test:*)",
      "Bash(yarn run:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm run:*)",
      "Bash(pytest:*)",
      "Bash(python -m pytest:*)",
      "Bash(make:*)",
      "Bash(pip3 list:*)",
      "Bash(node --version)",
      "Bash(npm --version)",
      "Bash(python3 --version)",
      "Bash(./.ai-policy/scripts/run-validation.sh)",
      "Bash(./.ai-policy/scripts/install-hooks.sh)",
      "mcp__github__get_issue",
      "mcp__github__create_issue",
      "mcp__github__list_issues",
      "mcp__github__get_pull_request",
      "mcp__github__create_pull_request",
      "mcp__github__list_pull_requests"
    ],
    "deny": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__.*github.*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.ai-policy/hooks/block-protected-branch-mcp.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit *)",
            "command": "bash \"$(git rev-parse --show-toplevel)/.ai-policy/hooks/block-protected-branch-bash.sh\""
          },
          {
            "type": "command",
            "if": "Bash(git push *)",
            "command": "bash \"$(git rev-parse --show-toplevel)/.ai-policy/hooks/block-protected-branch-bash.sh\""
          }
        ]
      }
    ]
  }
}
